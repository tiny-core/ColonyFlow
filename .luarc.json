{
    "$schema": "https://raw.githubusercontent.com/LuaLS/vscode-lua/master/setting/schema.json",
    "workspace.library": [
        "cclib/types",
        "${addons}/cc-tweaked/module/library"
    ],
    "runtime.version": "Lua 5.3",
    "hint.enable": false,
    "runtime.builtin": {
        "bit": "disable",
        "bit32": "enable",
        "utf8": "enable",
        "io": "disable",
        "os": "disable"
    }
}